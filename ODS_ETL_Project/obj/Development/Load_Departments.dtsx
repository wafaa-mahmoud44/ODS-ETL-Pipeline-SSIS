      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{59D45F8E-864D-4B9F-9877-BB07440E78AE}"
          SQLTask:SqlStatementSource="UPDATE tgt&#xA;SET tgt.DepartmentName = src.DepartmentName,&#xA;    tgt.ODSModifiedDate = GETDATE()&#xA;FROM [int].Departments tgt&#xA;JOIN stg.Departments src &#xA;    ON tgt.SourceDepartmentID = src.DepartmentID;&#xA;&#xA;INSERT INTO [int].Departments &#xA;    (SourceDepartmentID, DepartmentName, SourceSystem)&#xA;SELECT &#xA;    src.DepartmentID,&#xA;    src.DepartmentName,&#xA;    src.SourceSystem&#xA;FROM stg.Departments src&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM [int].Departments tgt&#xA;    WHERE tgt.SourceDepartmentID = src.DepartmentID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
