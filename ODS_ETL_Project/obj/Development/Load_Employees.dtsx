          SQLTask:SqlStatementSource="INSERT INTO meta.ETL_ExecutionLog&#xA;(PackageName, ExecutionStartTime, ExecutionEndTime,&#xA; RowsExtracted, RowsLoaded, Status)&#xA;VALUES&#xA;('Load_Employees', GETDATE(), GETDATE(), ?, ?, 'Success')" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
