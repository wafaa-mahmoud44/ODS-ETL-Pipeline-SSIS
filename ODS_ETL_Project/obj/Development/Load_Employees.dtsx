    <DTS:Executable
      DTS:refId="Package\Merge Employees to Integration"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0DE8C136-6B06-46DE-98D1-986516D27124}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge Employees to Integration"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{59D45F8E-864D-4B9F-9877-BB07440E78AE}"
          SQLTask:SqlStatementSource="&#xA;UPDATE tgt&#xA;SET tgt.EmployeeName = src.EmployeeName,&#xA;    tgt.DepartmentKey = src.DepartmentKey,&#xA;    tgt.Salary = src.Salary,&#xA;    tgt.ODSModifiedDate = GETDATE()&#xA;FROM [int].Employees tgt&#xA;JOIN stg.Employees src &#xA;    ON tgt.SourceEmployeeID = src.EmployeeID;&#xA;&#xA;&#xA;INSERT INTO [int].Employees&#xA;    (SourceEmployeeID, EmployeeName, DepartmentKey, Salary, SourceSystem)&#xA;SELECT&#xA;    src.EmployeeID,&#xA;    src.EmployeeName,&#xA;    src.DepartmentKey,&#xA;    src.Salary,&#xA;    src.SourceSystem&#xA;FROM stg.Employees src&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM [int].Employees tgt&#xA;    WHERE tgt.SourceEmployeeID = src.EmployeeID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
